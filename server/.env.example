PORT=5000
# If your MongoDB password contains "@", encode it as "%40" inside the URI.
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/collaborative-editor?retryWrites=true&w=majority
# Use a comma-separated list if you want to allow both local and deployed frontends.
CLIENT_URL=http://localhost:5173
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
